FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key

# MongoDB Atlas — database name lấy từ path trong URI (vd: .../cochibrightfuture)
# Hoặc set riêng MONGODB_DB nếu URI không có tên database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/cochibrightfuture?retryWrites=true&w=majority
# MONGODB_DB=cochibrightfuture

# Cloudinary — dùng CLOUDINARY_URL (khuyến nghị)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_FOLDER_PREFIX=cochibrightfuture

# Cloudinary — cách cũ (tùy chọn, nếu không dùng CLOUDINARY_URL)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kimchiltv3@gmail.com
SMTP_PASSWORD=your-app-password

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
